  "body_html": "<div class=\"header\">\n            <div class=\"h-icon\"><svg viewBox=\"0 0 24 24\"><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"/><line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"/><line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"/></svg></div>\n            <div class=\"h-title\">Bayesian inference</div>\n            <div class=\"h-icon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"5\" cy=\"12\" r=\"1.5\" fill=\"currentColor\"/><circle cx=\"12\" cy=\"12\" r=\"1.5\" fill=\"currentColor\"/><circle cx=\"19\" cy=\"12\" r=\"1.5\" fill=\"currentColor\"/></svg></div>\n          </div>\n\n          <div class=\"scroll\">\n            <div class=\"question\">What is Bayesian inference?</div>\n\n            <div class=\"src-label\">\n              <span class=\"mark-icon\" style=\"width:12px;height:12px;color:var(--teal)\"><svg><use href=\"#pplx-mark\"/></svg></span>\n              Sources\n            </div>\n            <div class=\"src-row\">\n              <div class=\"src-card\">\n                <div class=\"src-top\">\n                  <div class=\"src-fav wiki\">W</div>\n                  <div class=\"src-domain\">wikipedia.org</div>\n                  <div class=\"src-num\">1</div>\n                </div>\n                <div class=\"src-title\">Bayesian inference — Wikipedia</div>\n              </div>\n              <div class=\"src-card\">\n                <div class=\"src-top\">\n                  <div class=\"src-fav arx\">arXiv</div>\n                  <div class=\"src-domain\">arxiv.org</div>\n                  <div class=\"src-num\">2</div>\n                </div>\n                <div class=\"src-title\">A gentle introduction to probabilistic reasoning</div>\n              </div>\n            </div>\n\n            <div class=\"ans-header\">\n              <span class=\"mark-icon\" style=\"color:var(--teal)\"><svg><use href=\"#pplx-mark\"/></svg></span>\n              <span class=\"ans-label\">Answer</span>\n            </div>\n            <div class=\"ans-body\">\n              Bayesian inference is a method of statistical inference in which Bayes' theorem is used to <strong>update</strong> the probability for a hypothesis as more evidence becomes available <span class=\"cite\">1</span>. Unlike frequentist approaches, it treats probability as a degree of belief <span class=\"cite focus\">2</span>.<span class=\"cursor\"></span>\n            </div>\n          </div>\n\n          <div class=\"search-input\">\n            <div class=\"si-text\">Ask anything…</div>\n            <div class=\"si-attach\"><svg viewBox=\"0 0 24 24\"><path d=\"M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48\"/></svg></div>\n            <div class=\"si-send\"><svg viewBox=\"0 0 24 24\"><line x1=\"12\" y1=\"19\" x2=\"12\" y2=\"5\"/><polyline points=\"5 12 12 5 19 12\"/></svg></div>\n          </div>\n\n          <div class=\"tab-bar\">\n            <div class=\"tab active\"><svg viewBox=\"0 0 24 24\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg><span>Home</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><polygon points=\"16,8 14,14 8,16 10,10\" fill=\"currentColor\" stroke=\"none\"/></svg><span>Discover</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/><path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/></svg><span>Library</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/></svg><span>Spaces</span></div>\n          </div>",
