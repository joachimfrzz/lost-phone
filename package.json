  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "pngjs": "^7.0.0",
    "typescript": "~5.6.2",
    "vite": "^5.4.11"
