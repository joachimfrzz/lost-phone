    "captures:fix": "node scripts/captures-normalize.mjs",
    "captures:import": "node scripts/captures-import.mjs",
    "captures:import:min": "node scripts/captures-import.mjs --min",
    "captures:status": "node scripts/captures-status.mjs",
    "reference:measure": "node scripts/reference-measure.mjs",
    "wallpaper:bootstrap": "node scripts/bootstrap-wallpaper.mjs",
    "figma:export": "node scripts/figma-export-screen.mjs",
