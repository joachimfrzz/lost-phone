  "body_html": "<div class=\"status\"><span>9:41</span><span>●●● ▢</span></div>\n\n          <div class=\"reader\">\n            <div class=\"reader-head\">\n              <div class=\"ico-row\">\n                <svg viewBox=\"0 0 24 24\"><polyline points=\"15 18 9 12 15 6\"/></svg>\n              </div>\n              <div class=\"ico-row\">\n                <svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 7v5l3 3\"/></svg>\n                <svg viewBox=\"0 0 24 24\"><path d=\"M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z\"/></svg>\n                <svg viewBox=\"0 0 24 24\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.35-4.35\"/></svg>\n              </div>\n            </div>\n\n            <div class=\"reader-body\">\n              <div class=\"chap-num\">Chapter Seven</div>\n              <div class=\"chap-title\">The Lighthouse at Dawn</div>\n              <p class=\"reader-p\"><span class=\"drop\">T</span>he sea had been quiet for three days, and Mara had learned not to trust the quiet. She climbed the spiral stair before first light, counting the steps the way her father had taught her, each one worn soft by a century of keepers.</p>\n              <p class=\"reader-p\">At the top the lamp still turned, patient and enormous, throwing its long arm of light across water the color of slate. She rested her palm on the brass and felt the faint warmth that never quite left it.</p>\n              <p class=\"reader-p\">Below, the village was a scatter of dark roofs. Somewhere down there a boat was already missing, though no one knew it yet but her.</p>\n            </div>\n\n            <div class=\"reader-foot\">\n              <span>38%</span>\n              <div class=\"bar\"><i></i></div>\n              <span>14 min left in chapter</span>\n            </div>\n          </div>\n\n          <div class=\"reader-tb\">\n            <div class=\"tb-row\">\n              <div class=\"tb-btn aa\">Aa</div>\n              <div class=\"tb-btn\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"4\"/><path d=\"M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M17 7l2-2M5 19l2-2\"/></svg>Brightness</div>\n              <div class=\"tb-btn\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 6h16M4 12h16M4 18h10\"/></svg>Layout</div>\n              <div class=\"tb-btn\"><svg viewBox=\"0 0 24 24\"><path d=\"M3 5h18M3 12h18M3 19h18\"/></svg>Go To</div>\n            </div>\n            <div class=\"tb-themes\">\n              <span class=\"theme-dot white\"></span>\n              <span class=\"theme-dot sepia\"></span>\n              <span class=\"theme-dot green\"></span>\n              <span class=\"theme-dot dark\"></span>\n              <span class=\"theme-dot black\"></span>\n            </div>\n          </div>\n\n          <div class=\"tab-bar\">\n            <div class=\"tab active\"><svg viewBox=\"0 0 24 24\"><path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"/></svg><span>Home</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 19.5A2.5 2.5 0 0 1 6.5 17H20\"/><path d=\"M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z\"/></svg><span>Library</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.35-4.35\"/></svg><span>Discover</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><path d=\"M3 5h18v14H3z\"/><path d=\"M3 9h18\"/></svg><span>More</span></div>\n          </div>",
