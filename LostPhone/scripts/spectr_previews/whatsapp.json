  "body_html": "<div class=\"wall\"></div>\n          <div class=\"chat-nav\">\n            <div class=\"nav-back\">\n              <svg viewBox=\"0 0 24 24\"><polyline points=\"15,6 9,12 15,18\"/></svg>\n            </div>\n            <div class=\"nav-avatar\">MR</div>\n            <div class=\"nav-info\">\n              <div class=\"nav-name\">Maya Rivera</div>\n              <div class=\"nav-sub\">online</div>\n            </div>\n            <div class=\"nav-icons\">\n              <svg viewBox=\"0 0 24 24\"><polygon points=\"17,8 22,5 22,19 17,16\"/><rect x=\"2\" y=\"6\" width=\"15\" height=\"12\" rx=\"2\"/></svg>\n              <svg viewBox=\"0 0 24 24\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z\"/></svg>\n            </div>\n          </div>\n\n          <div class=\"chat-body\">\n            <div class=\"e2e-banner\">Messages and calls are end-to-end encrypted.</div>\n\n            <div class=\"bubble incoming\">Morning! Did the mockups get sent over last night? <span class=\"time\">10:21</span></div>\n            <div class=\"bubble outgoing\">Yep, the review file dropped in your inbox around 11pm. Look at the last two screens first. <span class=\"time\">10:24<span class=\"ticks\"><svg viewBox=\"0 0 16 10\"><path d=\"M1 5 l3 3 l7-7\" stroke=\"currentColor\" stroke-width=\"1.6\" fill=\"none\"/><path d=\"M5 5 l3 3 l7-7\" stroke=\"currentColor\" stroke-width=\"1.6\" fill=\"none\"/></svg></span></span></div>\n\n            <div class=\"bubble incoming\">Amazing, pulling it up now 🎉 <span class=\"time\">10:25</span></div>\n\n            <div class=\"bubble outgoing voice\">\n              <div class=\"voice-play\">\n                <svg viewBox=\"0 0 24 24\"><polygon points=\"6,4 20,12 6,20\"/></svg>\n              </div>\n              <div class=\"wave\">\n                <span style=\"height:30%\"></span><span style=\"height:50%\"></span><span style=\"height:70%\"></span><span style=\"height:45%\"></span><span style=\"height:85%\"></span><span style=\"height:65%\"></span><span style=\"height:40%\"></span><span style=\"height:75%\"></span><span style=\"height:55%\"></span><span style=\"height:90%\"></span><span style=\"height:60%\"></span><span style=\"height:35%\"></span><span style=\"height:70%\"></span><span style=\"height:50%\"></span><span style=\"height:80%\"></span>\n                <span class=\"off\" style=\"height:40%\"></span><span class=\"off\" style=\"height:60%\"></span><span class=\"off\" style=\"height:30%\"></span><span class=\"off\" style=\"height:75%\"></span><span class=\"off\" style=\"height:45%\"></span><span class=\"off\" style=\"height:65%\"></span><span class=\"off\" style=\"height:35%\"></span><span class=\"off\" style=\"height:55%\"></span><span class=\"off\" style=\"height:70%\"></span><span class=\"off\" style=\"height:40%\"></span><span class=\"off\" style=\"height:60%\"></span><span class=\"off\" style=\"height:30%\"></span><span class=\"off\" style=\"height:50%\"></span><span class=\"off\" style=\"height:65%\"></span><span class=\"off\" style=\"height:45%\"></span>\n              </div>\n              <div class=\"voice-dur\">0:23</div>\n              <span class=\"time\" style=\"right:10px; bottom:3px;\">10:27<span class=\"ticks\"><svg viewBox=\"0 0 16 10\"><path d=\"M1 5 l3 3 l7-7\" stroke=\"currentColor\" stroke-width=\"1.6\" fill=\"none\"/><path d=\"M5 5 l3 3 l7-7\" stroke=\"currentColor\" stroke-width=\"1.6\" fill=\"none\"/></svg></span></span>\n            </div>\n\n            <div class=\"bubble incoming\">This is gorgeous. Calling in 2 <span class=\"time\">10:29</span></div>\n          </div>\n\n          <div class=\"input-bar\">\n            <div class=\"input-field\">\n              <div class=\"emoji\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M8 14s1.5 2 4 2 4-2 4-2\"/><line x1=\"9\" y1=\"9\" x2=\"9.01\" y2=\"9\"/><line x1=\"15\" y1=\"9\" x2=\"15.01\" y2=\"9\"/></svg></div>\n              <div class=\"ph\">Message</div>\n              <div class=\"attach\"><svg viewBox=\"0 0 24 24\"><path d=\"M21 15.5V6a4 4 0 0 0-8 0v12a2 2 0 1 0 4 0V8\"/></svg></div>\n              <div class=\"attach\"><svg viewBox=\"0 0 24 24\"><path d=\"M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z\"/><circle cx=\"12\" cy=\"13\" r=\"4\"/></svg></div>\n            </div>\n            <div class=\"send-circle\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M12 1v22m-5-5l5 5 5-5\"/><path d=\"M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7\" fill=\"#fff\" stroke=\"none\"/><rect x=\"8\" y=\"3\" width=\"8\" height=\"14\" rx=\"4\"/></svg>\n            </div>\n          </div>\n\n          <div class=\"tab-bar\">\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><path d=\"M12 2a10 10 0 0 1 10 10c0 5-4 10-10 10a10 10 0 0 1-5-1.3L2 22l1.3-5A10 10 0 0 1 2 12a10 10 0 0 1 10-10z\"/></svg><span>Updates</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z\"/></svg><span>Calls</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg><span>Communities</span></div>\n            <div class=\"tab active\"><svg viewBox=\"0 0 24 24\"><path d=\"M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z\"/></svg><span>Chats</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24