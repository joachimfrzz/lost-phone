  "body_html": "<div class=\"appbar\">\n            <div class=\"appbar-menu\"><svg viewBox=\"0 0 24 24\"><line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\"/><line x1=\"3\" y1=\"12\" x2=\"21\" y2=\"12\"/><line x1=\"3\" y1=\"18\" x2=\"21\" y2=\"18\"/></svg></div>\n            <div class=\"appbar-title\">May 2026</div>\n            <div class=\"appbar-icon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg></div>\n            <div class=\"appbar-icon\"><svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><circle cx=\"12\" cy=\"13\" r=\"3\" fill=\"var(--blue)\" stroke=\"var(--blue)\"/></svg></div>\n          </div>\n\n          <div class=\"schedule\">\n            <div class=\"day-banner\">\n              <div class=\"day-number-today\">14</div>\n              <div class=\"day-banner-left\">\n                <div class=\"day-label\">Thu · May</div>\n                <div style=\"font-size:11px;color:var(--secondary);\">Today</div>\n              </div>\n              <div class=\"day-weather\">\n                <svg viewBox=\"0 0 24 24\" fill=\"var(--yellow)\"><circle cx=\"12\" cy=\"12\" r=\"4\"/><line x1=\"12\" y1=\"3\" x2=\"12\" y2=\"5\" stroke=\"var(--yellow)\" stroke-width=\"2\"/><line x1=\"12\" y1=\"19\" x2=\"12\" y2=\"21\" stroke=\"var(--yellow)\" stroke-width=\"2\"/><line x1=\"5\" y1=\"12\" x2=\"3\" y2=\"12\" stroke=\"var(--yellow)\" stroke-width=\"2\"/><line x1=\"21\" y1=\"12\" x2=\"19\" y2=\"12\" stroke=\"var(--yellow)\" stroke-width=\"2\"/></svg>\n                <span class=\"day-temp\">72°</span>\n              </div>\n            </div>\n\n            <div class=\"event\">\n              <div class=\"event-bar\" style=\"background:var(--blueberry)\"></div>\n              <div class=\"event-body\">\n                <div class=\"event-title\">Stand-up</div>\n                <div class=\"event-time\">9:00 – 9:30 AM</div>\n                <div class=\"event-meet\