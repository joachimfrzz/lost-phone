iv class=\"event-title\">Yoga · 30 min</div>\n                <div class=\"event-time\">6:30 – 7:00 PM</div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"fab\"><svg viewBox=\"0 0 24 24\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></div>\n\n          <div class=\"tab-bar\">\n            <div class=\"tab active\"><svg viewBox=\"0 0 24 24\"><line x1=\"8\" y1=\"6\" x2=\"21\" y2=\"6\"/><line x1=\"8\" y1=\"12\" x2=\"21\" y2=\"12\"/><line x1=\"8\" y1=\"18\" x2=\"21\" y2=\"18\"/><circle cx=\"4\" cy=\"6\" r=\"1.5\" fill=\"currentColor\"/><circle cx=\"4\" cy=\"12\" r=\"1.5\" fill=\"currentColor\"/><circle cx=\"4\" cy=\"18\" r=\"1.5\" fill=\"currentColor\"/></svg><span>Schedule</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/></svg><span>Day</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"4\" width=\"18\" height=\"18\" rx=\"2\"/><line x1=\"3\" y1=\"10\" x2=\"21\" y2=\"10\"/><line x1=\"8\" y1=\"2\" x2=\"8\" y2=\"6\"/><line x1=\"16\" y1=\"2\" x2=\"16\" y2=\"6\"/><line x1=\"7\" y1=\"14\" x2=\"7\" y2=\"18\"/><line x1=\"12\" y1=\"14\" x2=\"12\" y2=\"18\"/><line x1=\"17\" y1=\"14\" x2=\"17\" y2=\"18\"/></svg><span>Week</span></div>\n            <div class=\"tab\"><svg viewBox=\"0 0 24 24\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/></svg><span>Month</span></div>\n          </div>",
