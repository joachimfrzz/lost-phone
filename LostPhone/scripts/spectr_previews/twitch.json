  "body_html": "<div class=\"player\">\n            <div class=\"live-pill\"><span class=\"live-dot\"></span>LIVE</div>\n            <div class=\"viewer-pill\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"8\" r=\"4\"/><path d=\"M4 21c0-4 4-6 8-6s8 2 8 6\"/></svg>12.4K</div>\n          </div>\n\n          <div class=\"ch-bar\">\n            <div class=\"ch-ring\"><span class=\"ch-avatar\"></span></div>\n            <div class=\"ch-info\">\n              <div class=\"ch-name\">novaplays</div>\n              <div class=\"ch-meta\">Just Chatting · 12.4K</div>\n            </div>\n            <button class=\"follow-btn\"><svg viewBox=\"0 0 24 24\"><path d=\"M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21.2l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.8z\"/></svg>Follow</button>\n          </div>\n\n          <div class=\"chat\">\n            <div class=\"chat-head\">Stream Chat</div>\n            <div class=\"chat-body\">\n              <div class=\"chat-line\"><span class=\"cu\" style=\"color:#FF7EDB\">pixelgremlin</span>: that clutch was insane <span class=\"emote\"></span></div>\n              <div class=\"chat-line\"><span class=\"cu\" style=\"color:#5BC8FF\">harborwave</span>: GG well played</div>\n              <div class=\"chat-line mention\"><span class=\"cu\" style=\"color:#7BE38A\">modbot</span>: @you welcome to the stream!</div>\n              <div class=\"chat-line\"><span class=\"cu\" style=\"color:#FFB454\">kellen_v</span>: <span class=\"emote\"></span><span class=\"emote\"></span> let's gooo</div>\n              <div class=\"chat-line\"><span class=\"cu\" style=\"color:#C792EA\">hana.r</span>: what rank is this</div>\n              <div class=\"chat-line\"><span class=\"cu\" style=\"color:#FF6B6B\">drift_</span>: pog moment honestly</div>\n              <div class=\"chat-line\"><span class=\"cu\" style=\"color:#5BC8FF\">harborwave</span>: subbed for 6 months <span class=\"emote\"></span></div>\n            </div>\n            <div class=\